<!DOCTYPE html>
<html>
<head>
  <%- include ("../partials/header.ejs") %>
  <style>
    body {
      margin: 0;
      font-family: 'Segoe UI', sans-serif;
      background: #f3f6fb;
      color: #111827;
      padding: 0;
    }

    .top-bar {
      position: sticky;
      top: 0;
      left: 0;
      right: 0;
      min-height: 64px;
      background: #1d4ed8;
      color: white;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 20px;
      z-index: 1000;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
      gap: 12px;
      flex-wrap: wrap;
    }

    .top-status {
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
    }

    .status-chip,
    .status-toggle {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.15);
      color: #f8fafc;
      font-weight: 600;
      backdrop-filter: blur(6px);
    }

    .status-toggle input {
      margin: 0;
    }

    .bottom-bar {
      position: sticky;
      bottom: 0;
      left: 0;
      right: 0;
      min-height: 76px;
      background: #111827;
      color: white;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 12px 16px;
      z-index: 1000;
      font-size: 0.95rem;
      gap: 12px;
      flex-wrap: wrap;
    }

    .bottom-controls {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 8px;
    }

    .layout {
      display: grid;
      grid-template-columns: 270px minmax(0, 1fr) 320px;
      gap: 20px;
      padding: 20px;
    }

    .panel {
      background: white;
      border-radius: 12px;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
      padding: 16px;
    }

    .panel h3, .panel h4 {
      margin-top: 0;
    }

    .center-column {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .board-panel {
      background: #87ceeb;
      min-height: 540px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding: 20px;
      gap: 12px;
    }

    .board-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      width: 100%;
      gap: 12px;
    }

    .board-actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .bank-panel {
      width: 100%;
      background: white;
      border-radius: 12px;
      padding: 14px;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    }

    .bank-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
      margin-top: 10px;
    }

    .hexagon {
      width: 180px;
      height: 180px;
      background: #f8fafc;
      clip-path: polygon(25% 6.7%, 75% 6.7%, 100% 50%, 75% 93.3%, 25% 93.3%, 0% 50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      font-weight: 700;
      color: #1f2937;
      box-shadow: inset 0 0 0 2px rgba(0, 0, 0, 0.08);
      text-align: center;
      padding: 10px;
    }

    .resource-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-top: 10px;
    }

    .resource-item {
      display: flex;
      justify-content: space-between;
      padding: 8px 10px;
      background: #f8fafc;
      border-radius: 8px;
      border: none;
      width: 100%;
      text-align: left;
      align-items: center;
    }

    .resource-item:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }

    .resource-item:hover:not(:disabled) {
      background: #eef2ff;
      cursor: pointer;
    }

    .hand-group {
      margin-top: 12px;
    }

    .hand-group-title {
      font-size: 0.9rem;
      font-weight: 700;
      color: #374151;
      margin-bottom: 8px;
    }

    .hand-chip-list {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .hand-chip {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 4px;
      padding: 5px 9px;
      border-radius: 999px;
      background: #eef2ff;
      color: #1e40af;
      font-size: 0.78rem;
      font-weight: 700;
      border: none;
      line-height: 1;
    }

    .hand-chip-action:hover:not(:disabled) {
      background: #dbeafe;
      cursor: pointer;
    }

    .hand-chip:disabled {
      opacity: 0.55;
      cursor: not-allowed;
    }

    .dev-card-section {
      margin-top: 12px;
      padding-top: 10px;
      border-top: 1px solid #e5e7eb;
    }

    .dev-card-section-title {
      font-size: 0.95rem;
      font-weight: 700;
      margin-bottom: 8px;
    }

    .player-secondary-metrics {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
      margin-top: 4px;
    }

    .mini-pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 3px 6px;
      border-radius: 999px;
      background: #e0f2fe;
      color: #075985;
      font-size: 0.72rem;
      font-weight: 700;
    }

    .dev-card-button {
      width: 100%;
      text-align: left;
      border: none;
    }

    .special-marker {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 24px;
      height: 24px;
      margin-left: 4px;
      border-radius: 999px;
      background: #dc2626;
      color: white;
      font-size: 0.72rem;
      font-weight: 700;
      line-height: 1;
    }

    .event-log-box {
      max-height: 220px;
      overflow-y: auto;
      padding-right: 6px;
    }

    .event-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .event-item {
      font-size: 0.9rem;
      padding: 8px 10px;
      background: #f8fafc;
      border-radius: 8px;
    }

    .player-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-top: 10px;
    }

    .player-entry {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      padding: 8px 10px;
      background: #f8fafc;
      border-radius: 8px;
      align-items: center;
    }

    .player-metrics {
      display: flex;
      gap: 6px;
      align-items: center;
    }

    .badge-pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 28px;
      padding: 4px 8px;
      border-radius: 999px;
      background: #dbeafe;
      color: #1d4ed8;
      font-size: 0.8rem;
      font-weight: 700;
    }

    .badge-pill-green {
      background: #dcfce7;
      color: #166534;
    }

    @media (max-width: 900px) {
      .layout {
        grid-template-columns: 1fr;
      }

      .board-panel {
        min-height: 360px;
      }
    }

    @media (max-width: 640px) {
      .top-bar {
        padding: 12px 14px;
      }

      .top-status {
        width: 100%;
        justify-content: space-between;
      }

      .bottom-bar {
        padding: 12px 14px;
      }

      .bottom-controls {
        width: 100%;
      }

      .layout {
        padding: 14px;
        gap: 14px;
      }

      .hexagon {
        width: 150px;
        height: 150px;
      }

      .bank-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <div class="top-bar">
    <div><strong>CatanLive</strong></div>
    <div class="top-status">
      <div id="playerNameBar" class="status-chip">Your name: Waiting for player name...</div>
      <label class="status-toggle">
        <input id="setupToggle" type="checkbox"> <span>Setup game</span>
      </label>
      <button id="undoButton" class="btn btn-outline-light btn-sm" disabled>Undo</button>
      <button id="flipButton" class="btn btn-light btn-sm">Flip the board</button>
    </div>
  </div>

  <div class="layout">
    <aside class="panel">
      <h3>Hand</h3>
      <div class="hand-group">
        <div class="hand-group-title">Pieces</div>
        <div id="handPieces" class="hand-chip-list"></div>
      </div>
      <div class="hand-group">
        <div class="hand-group-title">Resources</div>
        <div id="playerResources" class="hand-chip-list"></div>
      </div>
      <div class="dev-card-section">
        <div class="dev-card-section-title">Hidden Dev Cards</div>
        <div id="hiddenDevelopmentCards" class="hand-chip-list"></div>
      </div>
    </aside>

    <main class="center-column">
      <div class="panel board-panel">
        <div class="board-header">
          <h3>Board</h3>
          <div class="board-actions">
            <button id="randomTileButton" class="btn btn-info" disabled>Random Tiles</button>
            <button id="randomPipButton" class="btn btn-warning" disabled>Random Pips</button>
          </div>
        </div>
        <div id="rollDisplay" class="mb-2"><strong>Last roll:</strong> None</div>
        <div id="hexagon" class="hexagon"><span id="hexagonText">Hexagon</span><span id="hexagonPip">-</span></div>
      </div>
      <div class="panel bank-panel">
        <h4>Bank</h4>
        <div id="bankResources" class="bank-grid"></div>
      </div>
    </main>

    <aside class="panel">
      <h3>Log</h3>
      <div class="event-log-box">
        <ul id="eventList" class="event-list"></ul>
      </div>
      <h4 class="mt-3">Players</h4>
      <div id="playerList" class="player-list"></div>
    </aside>
  </div>

  <div class="bottom-bar">
    <div class="bottom-controls">
      <button id="rollButton" class="btn btn-success" disabled>Roll Dice</button>
      <button id="roadButton" class="btn btn-info" disabled>Place Road</button>
      <button id="settlementButton" class="btn btn-warning" disabled>Place Settlement</button>
      <button id="cityButton" class="btn btn-danger" disabled>Place City</button>
      <button id="longestRoadButton" class="btn btn-outline-light" disabled>Take Longest Road</button>
      <button id="largestArmyButton" class="btn btn-outline-light" disabled>Take Largest Army</button>
    </div>
  </div>

  <script src="https://code.jquery.com/jquery-3.3.1.slim.min.js" integrity="sha384-q8i/X+965DzO0rT7abK41JStQIAqVgRVzpbzo5smXKp4YfRvH+8abtTE1Pi6jizo" crossorigin="anonymous"></script>
  <script src="https://cdn.jsdelivr.net/npm/popper.js@1.14.7/dist/umd/popper.min.js" integrity="sha384-UO2eT0CpHqdSJQ6hJty5KVphtPhzWj9WO1clHTMGa3JDZwrnQq4sF86dIHNDz0W1" crossorigin="anonymous"></script>
  <script>
    const initialState = <%- JSON.stringify(initialState) %>
    const STORAGE_KEY = 'catanlive_player'
    let currentPlayerId = null
    let currentPlayerName = ''
    let state = initialState
    let actionInFlight = false

    const playerNameBar = document.getElementById('playerNameBar')
    const handPieces = document.getElementById('handPieces')
    const playerResources = document.getElementById('playerResources')
    const hiddenDevelopmentCards = document.getElementById('hiddenDevelopmentCards')
    const bankResources = document.getElementById('bankResources')
    const playerList = document.getElementById('playerList')
    const eventList = document.getElementById('eventList')
    const rollDisplay = document.getElementById('rollDisplay')
    const rollButton = document.getElementById('rollButton')
    const randomTileButton = document.getElementById('randomTileButton')
    const randomPipButton = document.getElementById('randomPipButton')
    const roadButton = document.getElementById('roadButton')
    const settlementButton = document.getElementById('settlementButton')
    const cityButton = document.getElementById('cityButton')
    const longestRoadButton = document.getElementById('longestRoadButton')
    const largestArmyButton = document.getElementById('largestArmyButton')
    const setupToggle = document.getElementById('setupToggle')
    const undoButton = document.getElementById('undoButton')
    const flipButton = document.getElementById('flipButton')
    const hexagon = document.getElementById('hexagon')
    const hexagonText = document.getElementById('hexagonText')
    const hexagonPip = document.getElementById('hexagonPip')

    const resourceColors = {
      Sheep: '#86efac',
      Wheat: '#facc15',
      Ore: '#9ca3af',
      Wood: '#15803d',
      Brick: '#b45309'
    }

    function getCurrentPlayer() {
      return state.players.find((player) => player.id === currentPlayerId) || null
    }

    function clearPlayerIdentity() {
      localStorage.removeItem(STORAGE_KEY)
      currentPlayerId = null
      currentPlayerName = ''
    }

    function getDevelopmentCardTotal(player) {
      return Object.values(player?.developmentCards || {}).reduce((total, value) => total + Number(value || 0), 0)
    }

    async function runAction(handler) {
      if (actionInFlight) {
        return null
      }

      actionInFlight = true
      render()

      try {
        return await handler()
      } finally {
        actionInFlight = false
        render()
      }
    }

    function render() {
      const currentPlayer = getCurrentPlayer()
      const bank = state.bank || { resources: {}, developmentCards: {} }
      const playerResourcesForHand = currentPlayer?.resources || {}

      playerNameBar.textContent = currentPlayer
        ? `Your name: ${currentPlayerName}`
        : 'Your name: Waiting for player name...'

      handPieces.innerHTML = ''
      ;[
        { key: 'roads', icon: '🛣️', label: 'Roads' },
        { key: 'settlements', icon: '🏠', label: 'Settlements' },
        { key: 'cities', icon: '🏰', label: 'Cities' }
      ].forEach((entry) => {
        const count = currentPlayer ? Number(currentPlayer[entry.key] || 0) : 0
        const item = document.createElement('span')
        item.className = 'hand-chip'
        item.title = entry.label
        item.textContent = `${entry.icon} ×${count}`
        handPieces.appendChild(item)
      })

      playerResources.innerHTML = ''
      ;[
        { key: 'Wheat', icon: '🌾' },
        { key: 'Sheep', icon: '🐑' },
        { key: 'Ore', icon: '⛰️' },
        { key: 'Wood', icon: '🌲' },
        { key: 'Brick', icon: '🧱' }
      ].forEach((resource) => {
        const count = currentPlayer ? (playerResourcesForHand[resource.key] || 0) : 0
        if (!currentPlayer || count <= 0) {
          return
        }

        const button = document.createElement('button')
        button.type = 'button'
        button.className = 'hand-chip hand-chip-action'
        button.textContent = `${resource.icon} ${resource.key} ×${count}`
        button.disabled = !currentPlayer || count <= 0 || actionInFlight
        button.title = count > 0 ? `Return 1 ${resource.key} to the bank` : `No ${resource.key}`
        button.addEventListener('click', () => {
          if (!currentPlayer) {
            return
          }
          handleReturnResource(resource.key)
        })
        playerResources.appendChild(button)
      })

      hiddenDevelopmentCards.innerHTML = ''
      ;[
        { key: 'knights', label: 'Knight', icon: '⚔️', playable: true },
        { key: 'victoryPoints', label: 'Victory Point', icon: '⭐', playable: false },
        { key: 'monopoly', label: 'Monopoly', icon: '⛓️', playable: true },
        { key: 'roadBuilding', label: 'Road Building', icon: '🛣️', playable: true },
        { key: 'yearOfPlenty', label: 'Year of Plenty', icon: '🌾', playable: true }
      ].forEach((entry) => {
        const count = currentPlayer ? (currentPlayer.developmentCards?.[entry.key] || 0) : 0
        if (!currentPlayer || count <= 0) {
          return
        }

        const button = document.createElement('button')
        button.type = 'button'
        button.className = 'hand-chip hand-chip-action'
        button.textContent = `${entry.icon} ${entry.label} ×${count}`
        button.disabled = !currentPlayer || count <= 0 || actionInFlight || Boolean(state.setupMode) || !entry.playable
        button.title = entry.playable ? `Play ${entry.label}` : `${entry.label} remains hidden until game end`
        button.addEventListener('click', () => {
          if (!currentPlayer || !entry.playable) {
            return
          }
          handlePlayDevelopmentCard(entry.key)
        })
        hiddenDevelopmentCards.appendChild(button)
      })

      bankResources.innerHTML = ''
      ;['Wheat', 'Sheep', 'Ore', 'Wood', 'Brick'].forEach((resource) => {
        const count = bank.resources?.[resource] || 0
        const button = document.createElement('button')
        button.type = 'button'
        button.className = 'resource-item'
        button.innerHTML = `<span style="color:${resourceColors[resource]}; font-weight:700;">${resource}</span><strong>${count}</strong>`
        button.disabled = !currentPlayer || count <= 0 || actionInFlight
        button.title = count > 0 ? `Take 1 ${resource} from the bank` : `No ${resource}`
        button.addEventListener('click', () => {
          if (!currentPlayer) {
            return
          }
          handleTakeResource(resource)
        })
        bankResources.appendChild(button)
      })

      const devButton = document.createElement('button')
      devButton.type = 'button'
      devButton.className = 'resource-item'
      const devCount = Object.values(bank.developmentCards || {}).reduce((sum, value) => sum + Number(value || 0), 0)
      devButton.innerHTML = '<span style="font-weight:700;">Dev. Card</span><strong>' + devCount + '</strong>'
      devButton.disabled = !currentPlayer || devCount <= 0 || Boolean(state.setupMode) || actionInFlight
      devButton.title = state.setupMode ? 'Development cards are only available when setup mode is off' : 'Take a development card from the bank'
      devButton.addEventListener('click', () => {
        if (!currentPlayer) {
          return
        }
        handleTakeDevelopmentCard()
      })
      bankResources.appendChild(devButton)

      playerList.innerHTML = ''
      for (let index = 0; index < 4; index += 1) {
        const player = state.players[index]
        const slot = player || {
          name: `Player ${index + 1}`,
          color: '#6b7280',
          count: 0,
          rolls: 0,
          resources: {}
        }
        const item = document.createElement('div')
        item.className = 'player-entry'
        const resourceTotal = Object.values(slot.resources || {}).reduce((sum, value) => sum + Number(value || 0), 0)
        const devTotal = getDevelopmentCardTotal(slot)
        const specialMarks = []
        if (slot.id === state.longestRoadPlayerId) {
          specialMarks.push('<span class="special-marker" title="Longest Road">LR</span>')
        }
        if (slot.id === state.largestArmyPlayerId) {
          specialMarks.push('<span class="special-marker" title="Largest Army">LA</span>')
        }
        const playedBreakdown = [
          { key: 'knights', label: '⚔️' },
          { key: 'monopoly', label: '⛓️' },
          { key: 'roadBuilding', label: '🛣️' },
          { key: 'yearOfPlenty', label: '🌾' }
        ].flatMap((entry) => {
          const count = slot.playedDevelopmentCards?.[entry.key] || 0
          if (count <= 0) {
            return []
          }

          const label = count > 1 ? `${entry.label}×${count}` : entry.label
          return [`<span class="mini-pill" title="${entry.key} ×${count}">${label}</span>`]
        }).join('')
        item.innerHTML = `
          <div>
            <div style="color:${slot.color}; font-weight:700;">${slot.name}${specialMarks.length ? ` ${specialMarks.join('')}` : ''}</div>
            <div class="player-secondary-metrics">${playedBreakdown}</div>
          </div>
          <div class="player-metrics">
            <span class="badge-pill" title="Resource cards">${resourceTotal}</span>
            <span class="badge-pill badge-pill-green" title="Hidden dev cards">${devTotal}</span>
          </div>
        `
        playerList.appendChild(item)
      }

      eventList.innerHTML = ''
      ;(state.eventLog || []).slice().reverse().forEach((entry) => {
        const item = document.createElement('li')
        item.className = 'event-item'
        item.textContent = entry
        eventList.appendChild(item)
      })

      if (state.lastRoll !== null && state.lastRollBy) {
        rollDisplay.innerHTML = `<strong>Last roll:</strong> ${state.lastRoll} by ${state.lastRollBy}`
      } else {
        rollDisplay.innerHTML = '<strong>Last roll:</strong> None'
      }

      if (state.boardResource) {
        hexagon.style.background = resourceColors[state.boardResource] || '#f8fafc'
        hexagonText.textContent = state.boardResource
      } else {
        hexagon.style.background = '#f8fafc'
        hexagonText.textContent = 'Hexagon'
      }

      hexagonPip.textContent = state.boardPip !== null && state.boardPip !== undefined ? state.boardPip : '-'

      setupToggle.checked = Boolean(state.setupMode)
      const controlsEnabled = Boolean(currentPlayer) && !actionInFlight
      const setupEnabled = controlsEnabled && state.setupMode

      rollButton.disabled = !controlsEnabled
      randomTileButton.disabled = !setupEnabled
      randomPipButton.disabled = !setupEnabled
      roadButton.disabled = !controlsEnabled || state.setupMode
      settlementButton.disabled = !controlsEnabled || state.setupMode
      cityButton.disabled = !controlsEnabled || state.setupMode
      longestRoadButton.disabled = !controlsEnabled
      largestArmyButton.disabled = !controlsEnabled
      undoButton.disabled = !controlsEnabled
    }

    function savePlayerIdentity(playerId, name) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify({ playerId, name }))
    }

    function loadPlayerIdentity() {
      const stored = localStorage.getItem(STORAGE_KEY)
      if (!stored) {
        return null
      }

      try {
        const parsed = JSON.parse(stored)
        if (parsed && parsed.playerId && parsed.name) {
          return parsed
        }
      } catch (error) {
        console.error(error)
      }

      return null
    }

    async function requestJson(url, body) {
      const response = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      })

      const data = await response.json().catch(() => ({}))
      if (!response.ok && data.error) {
        alert(data.error)
        return null
      }

      return data
    }

    async function joinPlayer(name) {
      const data = await requestJson('/join', { name })
      if (data && data.playerId) {
        currentPlayerId = data.playerId
        currentPlayerName = data.name
        state = data.state
        savePlayerIdentity(currentPlayerId, currentPlayerName)
        render()
      }
    }

    async function resumePlayer(playerId, name) {
      const data = await requestJson('/resume', { playerId, name })
      if (data && data.playerId) {
        currentPlayerId = data.playerId
        currentPlayerName = data.name
        state = data.state
        render()
        return true
      }

      return false
    }

    async function ensurePlayerSession(savedPlayer) {
      if (savedPlayer) {
        const resumed = await resumePlayer(savedPlayer.playerId, savedPlayer.name)
        if (resumed) {
          return true
        }
      }

      clearPlayerIdentity()

      const enteredName = window.prompt('Enter your player name', '')
      if (enteredName && enteredName.trim()) {
        await joinPlayer(enteredName.trim())
        return true
      }

      render()
      return false
    }

    async function handleTakeResource(resource) {
      await runAction(async () => {
        const data = await requestJson('/take-resource', { playerId: currentPlayerId, playerName: currentPlayerName, resource })
        if (data) {
          state = data.state
        }
      })
    }

    async function handleReturnResource(resource) {
      await runAction(async () => {
        const data = await requestJson('/return-resource', { playerId: currentPlayerId, playerName: currentPlayerName, resource })
        if (data) {
          state = data.state
        }
      })
    }

    async function handleTakeDevelopmentCard() {
      await runAction(async () => {
        const data = await requestJson('/take-development-card', { playerId: currentPlayerId, playerName: currentPlayerName })
        if (data) {
          state = data.state
        }
      })
    }

    async function handlePlayDevelopmentCard(cardKey) {
      await runAction(async () => {
        const data = await requestJson('/play-development-card', {
          playerId: currentPlayerId,
          playerName: currentPlayerName,
          cardKey
        })
        if (data) {
          state = data.state
        }
      })
    }

    async function handleTakeLongestRoad() {
      await runAction(async () => {
        const data = await requestJson('/take-longest-road', { playerId: currentPlayerId, playerName: currentPlayerName })
        if (data) {
          state = data.state
        }
      })
    }

    async function handleTakeLargestArmy() {
      await runAction(async () => {
        const data = await requestJson('/take-largest-army', { playerId: currentPlayerId, playerName: currentPlayerName })
        if (data) {
          state = data.state
        }
      })
    }

    rollButton.addEventListener('click', async () => {
      if (!currentPlayerId) {
        return
      }

      await runAction(async () => {
        const data = await requestJson('/roll-dice', { playerId: currentPlayerId, playerName: currentPlayerName })
        if (data) {
          state = data.state
        }
      })
    })

    randomTileButton.addEventListener('click', async () => {
      if (!currentPlayerId) {
        return
      }

      await runAction(async () => {
        const data = await requestJson('/random-tile', { playerId: currentPlayerId, playerName: currentPlayerName })
        if (data) {
          state = data.state
        }
      })
    })

    randomPipButton.addEventListener('click', async () => {
      if (!currentPlayerId) {
        return
      }

      await runAction(async () => {
        const data = await requestJson('/random-pips', { playerId: currentPlayerId, playerName: currentPlayerName })
        if (data) {
          state = data.state
        }
      })
    })

    roadButton.addEventListener('click', async () => {
      if (!currentPlayerId) {
        return
      }

      await runAction(async () => {
        const data = await requestJson('/build-road', { playerId: currentPlayerId, playerName: currentPlayerName })
        if (data) {
          state = data.state
        }
      })
    })

    settlementButton.addEventListener('click', async () => {
      if (!currentPlayerId) {
        return
      }

      await runAction(async () => {
        const data = await requestJson('/build-settlement', { playerId: currentPlayerId, playerName: currentPlayerName })
        if (data) {
          state = data.state
        }
      })
    })

    cityButton.addEventListener('click', async () => {
      if (!currentPlayerId) {
        return
      }

      await runAction(async () => {
        const data = await requestJson('/build-city', { playerId: currentPlayerId, playerName: currentPlayerName })
        if (data) {
          state = data.state
        }
      })
    })

    longestRoadButton.addEventListener('click', async () => {
      if (!currentPlayerId) {
        return
      }

      await handleTakeLongestRoad()
    })

    largestArmyButton.addEventListener('click', async () => {
      if (!currentPlayerId) {
        return
      }

      await handleTakeLargestArmy()
    })

    setupToggle.addEventListener('change', async () => {
      const nextMode = setupToggle.checked
      state.setupMode = nextMode
      render()

      const data = await requestJson('/toggle-setup', {
        enabled: nextMode,
        playerId: currentPlayerId,
        playerName: currentPlayerName
      })

      if (data) {
        state = data.state
      } else {
        state.setupMode = !nextMode
      }

      render()
    })

    undoButton.addEventListener('click', async () => {
      if (!currentPlayerId) {
        return
      }

      await runAction(async () => {
        const data = await requestJson('/undo', { playerId: currentPlayerId, playerName: currentPlayerName })
        if (data) {
          state = data.state
        }
      })
    })

    flipButton.addEventListener('click', async () => {
      const confirmed = window.confirm('Flip the board and reset the game for everyone?')
      if (!confirmed) {
        return
      }

      await runAction(async () => {
        const data = await requestJson('/reset-game', {
          playerId: currentPlayerId,
          playerName: currentPlayerName
        })
        if (data) {
          clearPlayerIdentity()
          state = data.state
        }
      })
    })

    const eventSource = new EventSource('/events')
    eventSource.addEventListener('state', (event) => {
      const incoming = JSON.parse(event.data)
      if (incoming.reset) {
        clearPlayerIdentity()
      }
      state = incoming
      render()
    })

    window.addEventListener('load', async () => {
      const savedPlayer = loadPlayerIdentity()
      await ensurePlayerSession(savedPlayer)
    })

    render()
  </script>
</body>
</html>
