<!DOCTYPE html>
<html>
<head>
  <%- include ("../partials/header.ejs") %>
  <style>
    body {
      margin: 0;
      font-family: 'Segoe UI', sans-serif;
      background: #f3f6fb;
      padding-top: 64px;
      padding-bottom: 72px;
      color: #111827;
    }

    .top-bar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: 64px;
      background: #1d4ed8;
      color: white;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0 20px;
      z-index: 1000;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
      gap: 12px;
    }

    .top-buttons {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .bottom-bar {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      min-height: 72px;
      background: #111827;
      color: white;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 20px;
      z-index: 1000;
      font-size: 0.95rem;
      gap: 12px;
    }

    .layout {
      display: grid;
      grid-template-columns: 250px minmax(0, 1fr) 300px;
      gap: 20px;
      padding: 20px;
    }

    .panel {
      background: white;
      border-radius: 12px;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
      padding: 16px;
    }

    .panel h3, .panel h4 {
      margin-top: 0;
    }

    .board-panel {
      background: #87ceeb;
      min-height: 540px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding: 20px;
    }

    .controls {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      justify-content: center;
      margin: 16px 0;
    }

    .hexagon {
      width: 180px;
      height: 180px;
      background: #f8fafc;
      clip-path: polygon(25% 6.7%, 75% 6.7%, 100% 50%, 75% 93.3%, 25% 93.3%, 0% 50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      font-weight: 700;
      color: #1f2937;
      margin-top: 12px;
      box-shadow: inset 0 0 0 2px rgba(0, 0, 0, 0.08);
      text-align: center;
      padding: 10px;
    }

    .resource-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-top: 10px;
    }

    .resource-item {
      display: flex;
      justify-content: space-between;
      padding: 8px 10px;
      background: #f8fafc;
      border-radius: 8px;
    }

    .event-log-box {
      max-height: 220px;
      overflow-y: auto;
      padding-right: 6px;
    }

    .event-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .event-item {
      font-size: 0.9rem;
      padding: 8px 10px;
      background: #f8fafc;
      border-radius: 8px;
    }

    .player-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-top: 10px;
    }

    .player-entry {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      padding: 8px 10px;
      background: #f8fafc;
      border-radius: 8px;
    }

    .badge-pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 28px;
      padding: 4px 8px;
      border-radius: 999px;
      background: #dbeafe;
      color: #1d4ed8;
      font-size: 0.8rem;
      font-weight: 700;
    }
  </style>
</head>
<body>
  <div class="top-bar">
    <div><strong>CatanLive</strong></div>
    <div id="playerNameBar">Your name: Waiting for player name...</div>
    <div class="top-buttons">
      <label class="mr-2">
        <input id="setupToggle" type="checkbox"> Setup game
      </label>
      <button id="flipButton" class="btn btn-light btn-sm">Flip the board</button>
    </div>
  </div>

  <div class="layout">
    <aside class="panel">
      <h3>Player Hand</h3>
      <div class="resource-list">
        <div class="resource-item"><span>Settlements</span><strong id="settlementCount">5</strong></div>
        <div class="resource-item"><span>Roads</span><strong id="roadCount">15</strong></div>
        <div class="resource-item"><span>Cities</span><strong id="cityCount">4</strong></div>
        <div class="resource-item"><span style="color:#ca8a04;">Wheat</span><strong id="wheatCount">0</strong></div>
        <div class="resource-item"><span style="color:#86efac;">Sheep</span><strong id="sheepCount">0</strong></div>
        <div class="resource-item"><span style="color:#9ca3af;">Ore</span><strong id="oreCount">0</strong></div>
        <div class="resource-item"><span style="color:#15803d;">Wood</span><strong id="woodCount">0</strong></div>
        <div class="resource-item"><span style="color:#b45309;">Brick</span><strong id="brickCount">0</strong></div>
      </div>
    </aside>

    <main class="panel board-panel">
      <h3>Board</h3>
      <div class="controls">
        <button id="countButton" class="btn btn-primary" disabled>Count</button>
        <button id="rollButton" class="btn btn-success" disabled>Roll Dice</button>
        <button id="randomTileButton" class="btn btn-info" disabled>Random Tiles</button>
        <button id="randomPipButton" class="btn btn-warning" disabled>Random Pips</button>
        <button id="roadButton" class="btn btn-info" disabled>Place Road</button>
        <button id="settlementButton" class="btn btn-warning" disabled>Place Settlement</button>
        <button id="cityButton" class="btn btn-danger" disabled>Place City</button>
      </div>
      <div id="rollDisplay" class="mb-2"><strong>Last roll:</strong> None</div>
      <div id="hexagon" class="hexagon"><span id="hexagonText">Hexagon</span><span id="hexagonPip">-</span></div>
    </main>

    <aside class="panel">
      <h3>Event Log</h3>
      <div class="event-log-box">
        <ul id="eventList" class="event-list"></ul>
      </div>
      <h4 class="mt-3">Players</h4>
      <div id="playerList" class="player-list"></div>
    </aside>
  </div>

  <div class="bottom-bar">
    <div><strong>End of Page</strong></div>
    <div>About the project: This webpage is developed for non commercial use. Author: Jordan Ducatel.</div>
    <div><strong>CatanLive</strong></div>
  </div>

  <script src="https://code.jquery.com/jquery-3.3.1.slim.min.js" integrity="sha384-q8i/X+965DzO0rT7abK41JStQIAqVgRVzpbzo5smXKp4YfRvH+8abtTE1Pi6jizo" crossorigin="anonymous"></script>
  <script src="https://cdn.jsdelivr.net/npm/popper.js@1.14.7/dist/umd/popper.min.js" integrity="sha384-UO2eT0CpHqdSJQ6hJty5KVphtPhzWj9WO1clHTMGa3JDZwrnQq4sF86dIHNDz0W1" crossorigin="anonymous"></script>
  <script>
    const initialState = <%- JSON.stringify(initialState) %>
    const STORAGE_KEY = 'catanlive_player'
    let currentPlayerId = null
    let currentPlayerName = ''
    let state = initialState

    const playerNameBar = document.getElementById('playerNameBar')
    const settlementCount = document.getElementById('settlementCount')
    const roadCount = document.getElementById('roadCount')
    const cityCount = document.getElementById('cityCount')
    const wheatCount = document.getElementById('wheatCount')
    const sheepCount = document.getElementById('sheepCount')
    const oreCount = document.getElementById('oreCount')
    const woodCount = document.getElementById('woodCount')
    const brickCount = document.getElementById('brickCount')
    const playerList = document.getElementById('playerList')
    const eventList = document.getElementById('eventList')
    const rollDisplay = document.getElementById('rollDisplay')
    const countButton = document.getElementById('countButton')
    const rollButton = document.getElementById('rollButton')
    const randomTileButton = document.getElementById('randomTileButton')
    const randomPipButton = document.getElementById('randomPipButton')
    const roadButton = document.getElementById('roadButton')
    const settlementButton = document.getElementById('settlementButton')
    const cityButton = document.getElementById('cityButton')
    const setupToggle = document.getElementById('setupToggle')
    const flipButton = document.getElementById('flipButton')
    const hexagon = document.getElementById('hexagon')
    const hexagonText = document.getElementById('hexagonText')
    const hexagonPip = document.getElementById('hexagonPip')

    const resourceColors = {
      Sheep: '#86efac',
      Wheat: '#facc15',
      Ore: '#9ca3af',
      Wood: '#15803d',
      Brick: '#b45309'
    }

    function getCurrentPlayer() {
      return state.players.find((player) => player.id === currentPlayerId) || null
    }

    function clearPlayerIdentity() {
      localStorage.removeItem(STORAGE_KEY)
      currentPlayerId = null
      currentPlayerName = ''
    }

    function render() {
      const currentPlayer = getCurrentPlayer()

      playerNameBar.textContent = currentPlayer
        ? `Your name: ${currentPlayerName}`
        : 'Your name: Waiting for player name...'

      if (currentPlayer) {
        settlementCount.textContent = currentPlayer.settlements
        roadCount.textContent = currentPlayer.roads
        cityCount.textContent = currentPlayer.cities
      } else {
        settlementCount.textContent = '5'
        roadCount.textContent = '15'
        cityCount.textContent = '4'
      }

      wheatCount.textContent = '0'
      sheepCount.textContent = '0'
      oreCount.textContent = '0'
      woodCount.textContent = '0'
      brickCount.textContent = '0'

      playerList.innerHTML = ''
      for (let index = 0; index < 4; index += 1) {
        const player = state.players[index]
        const slot = player || {
          name: `Player ${index + 1}`,
          color: '#6b7280',
          count: 0
        }
        const item = document.createElement('div')
        item.className = 'player-entry'
        item.innerHTML = `
          <span style="color:${slot.color}; font-weight:700;">${slot.name}</span>
          <span class="badge-pill">${slot.count}</span>
        `
        playerList.appendChild(item)
      }

      eventList.innerHTML = ''
      ;(state.eventLog || []).slice().reverse().forEach((entry) => {
        const item = document.createElement('li')
        item.className = 'event-item'
        item.textContent = entry
        eventList.appendChild(item)
      })

      if (state.lastRoll !== null && state.lastRollBy) {
        rollDisplay.innerHTML = `<strong>Last roll:</strong> ${state.lastRoll} by ${state.lastRollBy}`
      } else {
        rollDisplay.innerHTML = '<strong>Last roll:</strong> None'
      }

      if (state.boardResource) {
        hexagon.style.background = resourceColors[state.boardResource] || '#f8fafc'
        hexagonText.textContent = state.boardResource
      } else {
        hexagon.style.background = '#f8fafc'
        hexagonText.textContent = 'Hexagon'
      }

      hexagonPip.textContent = state.boardPip !== null && state.boardPip !== undefined ? state.boardPip : '-'

      setupToggle.checked = Boolean(state.setupMode)
      const controlsEnabled = Boolean(currentPlayer)
      const setupEnabled = controlsEnabled && state.setupMode

      countButton.disabled = !controlsEnabled
      rollButton.disabled = !controlsEnabled
      randomTileButton.disabled = !setupEnabled
      randomPipButton.disabled = !setupEnabled
      roadButton.disabled = !controlsEnabled || state.setupMode
      settlementButton.disabled = !controlsEnabled || state.setupMode
      cityButton.disabled = !controlsEnabled || state.setupMode
    }

    function savePlayerIdentity(playerId, name) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify({ playerId, name }))
    }

    function loadPlayerIdentity() {
      const stored = localStorage.getItem(STORAGE_KEY)
      if (!stored) {
        return null
      }

      try {
        const parsed = JSON.parse(stored)
        if (parsed && parsed.playerId && parsed.name) {
          return parsed
        }
      } catch (error) {
        console.error(error)
      }

      return null
    }

    async function requestJson(url, body) {
      const response = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      })

      const data = await response.json()
      if (data.error) {
        alert(data.error)
        return null
      }

      return data
    }

    async function joinPlayer(name) {
      const data = await requestJson('/join', { name })
      if (data && data.playerId) {
        currentPlayerId = data.playerId
        currentPlayerName = data.name
        state = data.state
        savePlayerIdentity(currentPlayerId, currentPlayerName)
        render()
      }
    }

    async function resumePlayer(playerId, name) {
      const data = await requestJson('/resume', { playerId, name })
      if (data && data.playerId) {
        currentPlayerId = data.playerId
        currentPlayerName = data.name
        state = data.state
        render()
      }
    }

    countButton.addEventListener('click', async () => {
      if (!currentPlayerId) {
        return
      }

      const data = await requestJson('/count', { playerId: currentPlayerId })
      if (data) {
        state = data.state
        render()
      }
    })

    rollButton.addEventListener('click', async () => {
      if (!currentPlayerId) {
        return
      }

      const data = await requestJson('/roll-dice', { playerId: currentPlayerId })
      if (data) {
        state = data.state
        render()
      }
    })

    randomTileButton.addEventListener('click', async () => {
      if (!currentPlayerId) {
        return
      }

      const data = await requestJson('/random-tile', { playerId: currentPlayerId })
      if (data) {
        state = data.state
        render()
      }
    })

    randomPipButton.addEventListener('click', async () => {
      if (!currentPlayerId) {
        return
      }

      const data = await requestJson('/random-pips', { playerId: currentPlayerId })
      if (data) {
        state = data.state
        render()
      }
    })

    roadButton.addEventListener('click', async () => {
      if (!currentPlayerId) {
        return
      }

      const data = await requestJson('/build-road', { playerId: currentPlayerId })
      if (data) {
        state = data.state
        render()
      }
    })

    settlementButton.addEventListener('click', async () => {
      if (!currentPlayerId) {
        return
      }

      const data = await requestJson('/build-settlement', { playerId: currentPlayerId })
      if (data) {
        state = data.state
        render()
      }
    })

    cityButton.addEventListener('click', async () => {
      if (!currentPlayerId) {
        return
      }

      const data = await requestJson('/build-city', { playerId: currentPlayerId })
      if (data) {
        state = data.state
        render()
      }
    })

    setupToggle.addEventListener('change', async () => {
      const data = await requestJson('/toggle-setup', { enabled: setupToggle.checked })
      if (data) {
        state = data.state
        render()
      }
    })

    flipButton.addEventListener('click', async () => {
      const confirmed = window.confirm('Flip the board and reset the game for everyone?')
      if (!confirmed) {
        return
      }

      const data = await requestJson('/reset-game', {})
      if (data) {
        clearPlayerIdentity()
        state = data.state
        render()
      }
    })

    const eventSource = new EventSource('/events')
    eventSource.addEventListener('state', (event) => {
      const incoming = JSON.parse(event.data)
      if (incoming.reset) {
        clearPlayerIdentity()
      }
      state = incoming
      render()
    })

    window.addEventListener('load', async () => {
      const savedPlayer = loadPlayerIdentity()
      if (savedPlayer) {
        await resumePlayer(savedPlayer.playerId, savedPlayer.name)
        return
      }

      const enteredName = window.prompt('Enter your player name', '')
      if (enteredName && enteredName.trim()) {
        await joinPlayer(enteredName.trim())
      } else {
        render()
      }
    })

    render()
  </script>
</body>
</html>
